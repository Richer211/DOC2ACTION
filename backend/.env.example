OPENAI_API_KEY=your_openai_api_key_here
# Use a cost-effective model for baseline comparison.
OPENAI_MODEL=gpt-4o-mini
# extractor mode: auto | rules | llm
DOC2ACTION_EXTRACTOR_MODE=auto

# Optional: persist OpenAI embedding vectors under this directory (SQLite).
# DOC2ACTION_RAG_EMBED_CACHE_DIR=/absolute/path/to/backend/.cache/embeddings

# Phase 7 — optional API key for POST /analyze (leave unset for local dev).
# DOC2ACTION_API_KEY=your_long_random_secret

# Phase 7 — SlowAPI limit for /analyze (default 60/minute per client IP).
# DOC2ACTION_RATE_LIMIT=60/minute

# Phase 7 — Redis + RQ for multi-process async jobs (optional). If unset, jobs stay in-memory.
# Start Redis: docker compose up -d redis (repo root)
# Worker: cd backend && python -m app.rq_worker
# DOC2ACTION_REDIS_URL=redis://127.0.0.1:6379/0
# DOC2ACTION_RQ_QUEUE=doc2action
# DOC2ACTION_RQ_JOB_TIMEOUT=600
# DOC2ACTION_RQ_RESULT_TTL=86400
# Linux 上若需与 macOS 一样避免 fork 子进程，可设：DOC2ACTION_RQ_SIMPLE_WORKER=1（python -m app.rq_worker 会选用 SimpleWorker）

# Phase 7 — Optional JWT (Bearer) for protected routes; use with POST /api/v1/auth/token
# DOC2ACTION_JWT_SECRET=change_me_to_a_long_random_string
# DOC2ACTION_DEMO_USER=demo
# DOC2ACTION_DEMO_PASSWORD=demo
# DOC2ACTION_JWT_EXPIRE_HOURS=24

# P0 — SQLite 分析记录（默认 backend/.cache/analyses.sqlite，已在 .gitignore）
# DOC2ACTION_ANALYSIS_DB=/absolute/path/to/analyses.sqlite

# P1 — 评测报告路径（默认 learning/报告与演示材料/reports/baseline-eval.md）
# DOC2ACTION_EVAL_REPORT_MD=/absolute/path/to/baseline-eval.md

# P2 — 知识库单篇文档最大字符数（可选，默认 500000）
# DOC2ACTION_KB_MAX_DOC_CHARS=500000
